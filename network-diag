#!/bin/sh
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

while true; do
    clear
    printf "${YELLOW}  Run: sh /usr/local/bin/toolkit-menu${NC}\n"
    printf "${CYAN}=== Network Diagnostics ===${NC}\n\n"
    printf "  ${BOLD}1)${NC} Show all interfaces and IPs\n"
    printf "  ${BOLD}2)${NC} Ping test (gateway + internet)\n"
    printf "  ${BOLD}3)${NC} DNS lookup\n"
    printf "  ${BOLD}4)${NC} Traceroute\n"
    printf "  ${BOLD}5)${NC} Download speed test\n"
    printf "  ${BOLD}6)${NC} Scan local network\n"
    printf "  ${BOLD}7)${NC} Connect WiFi\n"
    printf "  ${BOLD}0)${NC} Back to main menu\n"
    printf "\n  Choose: "; read CH

    case "$CH" in
        1)
            printf "\n"
            for iface in $(ls /sys/class/net/ 2>/dev/null); do
                [ "$iface" = "lo" ] && continue
                STATE=$(cat /sys/class/net/$iface/operstate 2>/dev/null)
                ADDR=$(ip -4 addr show "$iface" 2>/dev/null | grep "inet " | awk '{print $2}')
                MAC=$(cat /sys/class/net/$iface/address 2>/dev/null)
                WIFI=""
                [ -d "/sys/class/net/$iface/wireless" ] && WIFI=" (WiFi)"
                printf "  ${BOLD}%s${NC}%s: %s\n" "$iface" "$WIFI" "$STATE"
                printf "    IP: %s  MAC: %s\n" "${ADDR:-none}" "$MAC"
            done
            # Show gateway
            GW=$(ip route 2>/dev/null | grep default | awk '{print $3}' | head -1)
            DNS=$(cat /etc/resolv.conf 2>/dev/null | grep nameserver | head -1 | awk '{print $2}')
            printf "\n  Gateway: %s\n  DNS: %s\n" "${GW:-none}" "${DNS:-none}"
            printf "\nPress Enter..."; read dummy
            ;;
        2)
            GW=$(ip route 2>/dev/null | grep default | awk '{print $3}' | head -1)
            printf "\n  Pinging gateway (%s)...\n" "${GW:-none}"
            [ -n "$GW" ] && ping -c 3 "$GW" 2>&1 | tail -4
            printf "\n  Pinging 8.8.8.8 (Google DNS)...\n"
            ping -c 3 8.8.8.8 2>&1 | tail -4
            printf "\n  Pinging google.com...\n"
            ping -c 3 google.com 2>&1 | tail -4
            printf "\nPress Enter..."; read dummy
            ;;
        3)
            printf "\n  Domain to lookup [google.com]: "; read DOMAIN
            DOMAIN=${DOMAIN:-google.com}
            if command -v nslookup >/dev/null 2>&1; then
                nslookup "$DOMAIN" 2>&1
            else
                # Busybox fallback
                printf "  Resolving %s...\n" "$DOMAIN"
                ping -c 1 "$DOMAIN" 2>&1 | head -1
            fi
            printf "\nPress Enter..."; read dummy
            ;;
        4)
            printf "\n  Host [8.8.8.8]: "; read HOST
            HOST=${HOST:-8.8.8.8}
            if command -v traceroute >/dev/null 2>&1; then
                traceroute -m 15 "$HOST" 2>&1
            else
                printf "  Using ping-based trace...\n"
                I=1; while [ $I -le 15 ]; do
                    RESULT=$(ping -c 1 -t $I "$HOST" 2>&1 | grep -E "From|from|bytes from")
                    printf "  %2d: %s\n" "$I" "${RESULT:-*}"
                    echo "$RESULT" | grep -q "$HOST" && break
                    I=$((I+1))
                done
            fi
            printf "\nPress Enter..."; read dummy
            ;;
        5)
            printf "\n  Downloading 10MB test file...\n"
            START=$(date +%s)
            wget -O /dev/null "http://speedtest.tele2.net/10MB.zip" 2>&1 | tail -2
            END=$(date +%s)
            ELAPSED=$((END - START))
            [ "$ELAPSED" -gt 0 ] && printf "  Time: %ds (~%d Mbps)\n" "$ELAPSED" "$((80 / ELAPSED))"
            printf "\nPress Enter..."; read dummy
            ;;
        6)
            SUBNET=$(ip -4 addr 2>/dev/null | grep "inet " | grep -v 127.0.0.1 | head -1 | awk '{print $2}' | cut -d. -f1-3)
            if [ -n "$SUBNET" ]; then
                printf "\n  Scanning %s.0/24...\n" "$SUBNET"
                I=1; while [ $I -le 254 ]; do
                    ping -c 1 -W 1 "${SUBNET}.${I}" >/dev/null 2>&1 && printf "  ${GREEN}%s.%d is alive${NC}\n" "$SUBNET" "$I" &
                    I=$((I+1))
                    # Run 20 pings at a time
                    [ $((I % 20)) -eq 0 ] && wait
                done
                wait
            else
                printf "${RED}  No network connection.${NC}\n"
            fi
            printf "\nPress Enter..."; read dummy
            ;;
        7)
            WIFI_IF=""
            for iface in $(ls /sys/class/net/ 2>/dev/null); do
                [ -d "/sys/class/net/$iface/wireless" ] && WIFI_IF="$iface" && break
                iw dev "$iface" info >/dev/null 2>&1 && WIFI_IF="$iface" && break
            done
            if [ -n "$WIFI_IF" ]; then
                ip link set "$WIFI_IF" up 2>/dev/null; sleep 1
                printf "\n  Scanning...\n"
                iw "$WIFI_IF" scan 2>/dev/null | grep "SSID:" | sort -u | sed 's/.*SSID: //' | grep -v "^$" | while read s; do printf "    - %s\n" "$s"; done
                printf "\n  SSID: "; read SSID
                [ -z "$SSID" ] && continue
                printf "  Password: "; stty -echo 2>/dev/null; read WP; stty echo 2>/dev/null; printf "\n"
                killall wpa_supplicant 2>/dev/null
                wpa_passphrase "$SSID" "$WP" > /tmp/w.conf 2>/dev/null
                wpa_supplicant -B -i "$WIFI_IF" -c /tmp/w.conf 2>/dev/null
                sleep 5; udhcpc -i "$WIFI_IF" -q -t 5 -n 2>/dev/null
                printf "${GREEN}  Done!${NC}\n"
            else
                printf "${RED}  No WiFi adapter.${NC}\n"
            fi
            sleep 2
            ;;
        0) break ;;
    esac
done
