#!/bin/sh
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

while true; do
    clear
    printf "${YELLOW}  Run: sh /usr/local/bin/toolkit-menu${NC}\n"
    printf "${CYAN}=== Data Backup / File Recovery ===${NC}\n\n"
    printf "  ${BOLD}1)${NC} Browse files on a partition\n"
    printf "  ${BOLD}2)${NC} Backup Windows user folders to USB\n"
    printf "  ${BOLD}3)${NC} Copy files between partitions\n"
    printf "  ${BOLD}4)${NC} List mounted partitions\n"
    printf "  ${BOLD}5)${NC} Mount a partition\n"
    printf "  ${BOLD}0)${NC} Back to main menu\n"
    printf "\n  Choose: "; read CH

    case "$CH" in
        1)
            printf "\n  Enter path to browse [/mnt]: "; read BPATH
            BPATH=${BPATH:-/mnt}
            if command -v mc >/dev/null 2>&1; then
                mc "$BPATH"
            else
                printf "\n  Browsing %s (type 'cd DIR', 'ls', 'cat FILE', 'q' to quit)\n\n" "$BPATH"
                cd "$BPATH" 2>/dev/null || { printf "${RED}Invalid path.${NC}\n"; sleep 2; continue; }
                while true; do
                    printf "${GREEN}%s>${NC} " "$(pwd)"
                    read CMD
                    case "$CMD" in
                        q|quit|exit) break ;;
                        cd\ *) cd "$(echo "$CMD" | sed 's/^cd //')" 2>/dev/null || printf "Invalid dir\n" ;;
                        ls*) eval "$CMD" 2>/dev/null ;;
                        cat\ *) eval "$CMD" 2>/dev/null | head -50 ;;
                        cp\ *) eval "$CMD" 2>/dev/null && printf "Copied.\n" ;;
                        *) ls -la 2>/dev/null ;;
                    esac
                done
            fi
            ;;
        2)
            printf "\n  Scanning for Windows partitions...\n"
            BLKOUT=$(blkid 2>/dev/null)
            WINPART=""
            for p in /dev/sd*[0-9] /dev/nvme*p[0-9]*; do
                [ -b "$p" ] || continue
                echo "$BLKOUT" | grep "^${p}:" | grep -q 'TYPE="ntfs"' || continue
                LABEL=$(echo "$BLKOUT" | grep "^${p}:" | sed -n 's/.*LABEL="\([^"]*\)".*/\1/p')
                printf "  Found: %s (%s)\n" "$p" "${LABEL:-NTFS}"
                WINPART="$p"
            done
            [ -z "$WINPART" ] && { printf "${RED}  No NTFS partitions found.${NC}\n"; sleep 2; continue; }

            WMNT=$(mktemp -d)
            if [ -x /bin/ntfs-3g ]; then
                /bin/ntfs-3g -o ro,remove_hiberfile "$WINPART" "$WMNT" 2>/dev/null
            else
                mount -t ntfs3 -o ro,force "$WINPART" "$WMNT" 2>/dev/null
            fi

            # Find user folders
            USERS_DIR=""
            for d in "$WMNT/Users" "$WMNT/users"; do
                [ -d "$d" ] && USERS_DIR="$d" && break
            done
            if [ -z "$USERS_DIR" ]; then
                printf "${RED}  Could not find Users folder.${NC}\n"
                umount "$WMNT" 2>/dev/null; rmdir "$WMNT"; sleep 2; continue
            fi

            printf "\n  User folders found:\n"
            I=0
            UDIRS=""
            for d in "$USERS_DIR"/*/; do
                UNAME=$(basename "$d")
                case "$UNAME" in Public|Default|"Default User"|"All Users") continue ;; esac
                I=$((I+1))
                UDIRS="$UDIRS $UNAME"
                # Calculate size
                SIZE=$(du -sh "$d" 2>/dev/null | cut -f1)
                printf "    %d) %s (%s)\n" "$I" "$UNAME" "${SIZE:-?}"
            done

            printf "\n  Pick user to backup (number), or 'all': "; read PICK

            # Find destination (another USB or partition)
            printf "  Backup destination [/media/usb/backups]: "; read DEST
            DEST=${DEST:-/media/usb/backups}
            mkdir -p "$DEST" 2>/dev/null

            if [ "$PICK" = "all" ]; then
                for UNAME in $UDIRS; do
                    printf "  Backing up %s...\n" "$UNAME"
                    mkdir -p "$DEST/$UNAME"
                    for folder in Documents Desktop Pictures Downloads Music Videos; do
                        [ -d "$USERS_DIR/$UNAME/$folder" ] && cp -r "$USERS_DIR/$UNAME/$folder" "$DEST/$UNAME/" 2>/dev/null
                    done
                done
            else
                J=1
                for UNAME in $UDIRS; do
                    if [ "$J" -eq "$PICK" ]; then
                        printf "  Backing up %s...\n" "$UNAME"
                        mkdir -p "$DEST/$UNAME"
                        for folder in Documents Desktop Pictures Downloads Music Videos; do
                            [ -d "$USERS_DIR/$UNAME/$folder" ] && cp -r "$USERS_DIR/$UNAME/$folder" "$DEST/$UNAME/" 2>/dev/null
                        done
                        break
                    fi
                    J=$((J+1))
                done
            fi

            sync
            printf "${GREEN}  Backup complete! Saved to: %s${NC}\n" "$DEST"
            umount "$WMNT" 2>/dev/null; rmdir "$WMNT"
            printf "\nPress Enter..."; read dummy
            ;;
        3)
            printf "\n  Source file/folder: "; read SRC
            printf "  Destination: "; read DST
            if [ -e "$SRC" ]; then
                cp -rv "$SRC" "$DST" 2>&1 | tail -5
                sync
                printf "${GREEN}  Done.${NC}\n"
            else
                printf "${RED}  Source not found.${NC}\n"
            fi
            printf "\nPress Enter..."; read dummy
            ;;
        4)
            printf "\n"
            mount | grep -vE "tmpfs|proc|sys|devpts|cgroup"
            printf "\nPress Enter..."; read dummy
            ;;
        5)
            printf "\n  Partition (e.g. /dev/sda1): "; read PART
            [ -b "$PART" ] || { printf "${RED}Not valid.${NC}\n"; sleep 2; continue; }
            MNTPT="/mnt/$(basename $PART)"
            mkdir -p "$MNTPT"
            TYPE=$(blkid "$PART" 2>/dev/null | sed -n 's/.*TYPE="\([^"]*\)".*/\1/p')
            case "$TYPE" in
                ntfs)
                    if [ -x /bin/ntfs-3g ]; then
                        /bin/ntfs-3g -o ro,remove_hiberfile "$PART" "$MNTPT" 2>&1
                    else
                        mount -t ntfs3 -o ro,force "$PART" "$MNTPT" 2>&1
                    fi
                    ;;
                *) mount -o ro "$PART" "$MNTPT" 2>&1 ;;
            esac
            printf "Mounted at %s\n" "$MNTPT"
            printf "Press Enter..."; read dummy
            ;;
        0) break ;;
    esac
done
