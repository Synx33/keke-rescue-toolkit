#!/bin/sh
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

clear
printf "${YELLOW}  Run: sh /usr/local/bin/toolkit-menu${NC}\n"
printf "${CYAN}"
printf "==============================================\n"
printf "    Windows Account Password Reset Tool       \n"
printf "==============================================\n"
printf "${NC}\n"
printf "  Supports LOCAL and MICROSOFT accounts.\n\n"

# =============================================
# FIND THE USB DRIVE (search everywhere)
# =============================================
find_usb() {
    # Method 1: search all /media mounts
    for m in /media/* /media/*/*; do
        [ -d "$m/packages" ] && printf "%s" "$m" && return 0
    done
    # Method 2: search /mnt
    for m in /mnt/* /mnt/*/*; do
        [ -d "$m/packages" ] && printf "%s" "$m" && return 0
    done
    # Method 3: search /run/media
    for m in /run/media/* /run/media/*/*; do
        [ -d "$m/packages" ] && printf "%s" "$m" && return 0
    done
    # Method 4: find by label PWRESET and mount it
    USBDEV=$(blkid -L PWRESET 2>/dev/null)
    if [ -n "$USBDEV" ]; then
        mkdir -p /tmp/usb_mnt
        mount -t vfat "$USBDEV" /tmp/usb_mnt 2>/dev/null
        if [ -d "/tmp/usb_mnt/packages" ]; then
            printf "/tmp/usb_mnt" && return 0
        fi
    fi
    # Method 5: search by .alpine-release file on any mounted fs
    for m in /media/* /mnt/*; do
        [ -f "$m/.alpine-release" ] && printf "%s" "$m" && return 0
    done
    # Method 6: try to find and mount any FAT32 partition with our files
    for dev in $(blkid -t TYPE=vfat -o device 2>/dev/null); do
        mkdir -p /tmp/usb_try
        mount -t vfat "$dev" /tmp/usb_try 2>/dev/null || continue
        if [ -d "/tmp/usb_try/packages" ] || [ -f "/tmp/usb_try/.alpine-release" ]; then
            printf "/tmp/usb_try" && return 0
        fi
        umount /tmp/usb_try 2>/dev/null
    done
    return 1
}

printf "${GREEN}[*] Finding USB drive...${NC}\n"
USB_MNT=$(find_usb)
if [ -n "$USB_MNT" ]; then
    printf "${GREEN}    Found at: %s${NC}\n" "$USB_MNT"
else
    printf "${YELLOW}    Could not find USB mount. Trying to continue anyway...${NC}\n"
fi

# =============================================
# INSTALL TOOLS OFFLINE (extract .apk with tar)
# =============================================
install_tools() {
    if command -v chntpw >/dev/null 2>&1; then
        printf "${GREEN}    Tools already available.${NC}\n"
        return 0
    fi

    printf "${GREEN}[*] Checking tools...${NC}\n"

    # Load ntfs3 kernel module (built-in NTFS driver - no ntfs-3g needed)
    modprobe ntfs3 2>/dev/null

    # Check chntpw
    if ! command -v chntpw >/dev/null 2>&1; then
        printf "${RED}    chntpw not found. Trying to install...${NC}\n"
        ALPINE_VER=$(cat /etc/alpine-release 2>/dev/null | cut -d. -f1,2)
        if [ -n "$ALPINE_VER" ]; then
            grep -q community /etc/apk/repositories 2>/dev/null || \
                printf "https://dl-cdn.alpinelinux.org/alpine/v%s/community\n" "$ALPINE_VER" >> /etc/apk/repositories
        fi
        apk update --allow-untrusted >/dev/null 2>&1
        apk add --allow-untrusted chntpw >/dev/null 2>&1
    fi

    if ! command -v chntpw >/dev/null 2>&1; then
        printf "${RED}    FATAL: chntpw not available.${NC}\n"
        return 1
    fi

    printf "${GREEN}    Tools ready!${NC}\n"
    return 0
}

install_tools || { printf "\nPress Enter to drop to shell..."; read dummy; exit 1; }

# =============================================
# WIFI SETUP (optional - not needed for reset)
# =============================================
setup_wifi() {
    rfkill unblock wifi 2>/dev/null; rfkill unblock all 2>/dev/null
    # Load all common WiFi kernel modules
    for mod in cfg80211 mac80211 iwlwifi iwlmvm iwldvm ath10k_pci ath11k_pci \
               brcmfmac rtw88_pci rtw88_usb rtw89pci mt7921e mt7921s mt7922 \
               rtl8xxxu r8188eu 8821cu; do
        modprobe "$mod" 2>/dev/null
    done
    sleep 2

    WIFI_IF=""
    for iface in $(ls /sys/class/net/ 2>/dev/null); do
        [ -d "/sys/class/net/$iface/wireless" ] && WIFI_IF="$iface" && break
        [ -d "/sys/class/net/$iface/phy80211" ] && WIFI_IF="$iface" && break
        iw dev "$iface" info >/dev/null 2>&1 && WIFI_IF="$iface" && break
    done

    if [ -z "$WIFI_IF" ]; then
        printf "${YELLOW}    No WiFi adapter detected.${NC}\n"
        return 1
    fi

    ip link set "$WIFI_IF" up 2>/dev/null; sleep 1
    printf "${GREEN}    WiFi adapter: %s${NC}\n" "$WIFI_IF"
    printf "${GREEN}    Scanning...${NC}\n"
    NETWORKS=$(iw "$WIFI_IF" scan 2>/dev/null | grep "SSID:" | sort -u | sed 's/.*SSID: //' | grep -v "^$")
    [ -z "$NETWORKS" ] && printf "${YELLOW}    No networks found.${NC}\n" && return 1
    printf "%s\n" "$NETWORKS" | while read s; do printf "      - %s\n" "$s"; done

    printf "\n    Enter WiFi name (SSID): "; read SSID
    [ -z "$SSID" ] && return 1
    printf "    Enter password (blank=open): "
    stty -echo 2>/dev/null; read WIFIPASS; stty echo 2>/dev/null; printf "\n"
    killall wpa_supplicant 2>/dev/null

    WPA_CONF="/tmp/wpa.conf"
    if [ -n "$WIFIPASS" ]; then
        wpa_passphrase "$SSID" "$WIFIPASS" > "$WPA_CONF" 2>/dev/null
    else
        printf 'network={\n  ssid="%s"\n  key_mgmt=NONE\n}\n' "$SSID" > "$WPA_CONF"
    fi

    wpa_supplicant -B -i "$WIFI_IF" -c "$WPA_CONF" 2>/dev/null
    T=0; while [ $T -lt 10 ]; do
        sleep 1; wpa_cli -i "$WIFI_IF" status 2>/dev/null | grep -q "wpa_state=COMPLETED" && break; T=$((T+1))
    done
    udhcpc -i "$WIFI_IF" -q -t 5 -n 2>/dev/null
    printf "${GREEN}    WiFi connected!${NC}\n"
}

# Try ethernet silently
for iface in $(ls /sys/class/net/ 2>/dev/null); do
    case "$iface" in eth*|en*) ip link set "$iface" up 2>/dev/null; udhcpc -i "$iface" -q -t 2 -n 2>/dev/null;; esac
done

# =============================================
# FIND WINDOWS PARTITIONS
# =============================================
printf "\n${GREEN}[1/4] Scanning for Windows partitions...${NC}\n"
PARTS=""; COUNT=0
# Parse blkid output directly (busybox compatible)
BLKOUT=$(blkid 2>/dev/null)
for p in /dev/sd*[0-9] /dev/nvme*p[0-9]* /dev/mmcblk*p[0-9]*; do
    [ -b "$p" ] || continue
    echo "$BLKOUT" | grep "^${p}:" | grep -q 'TYPE="ntfs"' || continue
    PARTS="$PARTS $p"; COUNT=$((COUNT+1))
done
if [ "$COUNT" -eq 0 ]; then
    printf "${RED}No NTFS partitions found.${NC}\n"
    printf "Detected devices:\n"
    blkid 2>/dev/null
    printf "\nPress Enter to exit..."; read dummy; exit 1
fi
printf "\nFound NTFS partitions:\n"
I=0
for p in $PARTS; do
    LABEL=$(echo "$BLKOUT" | grep "^${p}:" | sed -n 's/.*LABEL="\([^"]*\)".*/\1/p')
    printf "  [%d] %s  (%s)\n" "$I" "$p" "${LABEL:-unknown}"; I=$((I+1))
done
printf "\n"
if [ "$COUNT" -eq 1 ]; then
    CHOSEN=$(printf '%s' "$PARTS" | tr -d ' ')
    printf "Auto-selected: %s\n" "$CHOSEN"
else
    printf "Select partition number: "; read PNUM
    I=0; for p in $PARTS; do [ "$I" -eq "$PNUM" ] && CHOSEN="$p" && break; I=$((I+1)); done
fi
[ -z "$CHOSEN" ] && printf "${RED}Invalid selection.${NC}\n" && exit 1

# =============================================
# MOUNT & FIND SAM
# =============================================
printf "\n${GREEN}[2/4] Mounting %s...${NC}\n" "$CHOSEN"
MNT=$(mktemp -d)
# ntfs-3g with remove_hiberfile is the ONLY reliable way to write
# to NTFS when Windows Fast Startup is enabled
export PATH="$PATH:/usr/sbin:/sbin"

MOUNT_OK=0
if command -v ntfs-3g >/dev/null 2>&1 || [ -x /usr/sbin/ntfs-3g ]; then
    printf "  Using ntfs-3g with force flags...\n"
    /usr/sbin/ntfs-3g -o rw,remove_hiberfile,big_writes "$CHOSEN" "$MNT" 2>&1
    MOUNT_OK=$?
    if [ $MOUNT_OK -ne 0 ]; then
        ntfs-3g -o rw,remove_hiberfile "$CHOSEN" "$MNT" 2>&1
        MOUNT_OK=$?
    fi
fi

# Fallback to kernel ntfs3 if ntfs-3g not available
if [ $MOUNT_OK -ne 0 ]; then
    mount -t ntfs3 -o rw,force "$CHOSEN" "$MNT" 2>/dev/null
    MOUNT_OK=$?
fi
if [ $MOUNT_OK -ne 0 ]; then
    mount -t ntfs3 -o rw,norecovery "$CHOSEN" "$MNT" 2>/dev/null
    MOUNT_OK=$?
fi
if [ $MOUNT_OK -ne 0 ]; then
    printf "${RED}Could not mount %s${NC}\n" "$CHOSEN"
    rmdir "$MNT"; exit 1
fi

# Verify we can write
touch "$MNT/.write_test" 2>/dev/null && rm -f "$MNT/.write_test" 2>/dev/null && \
    printf "${GREEN}Mounted read-write. Write access confirmed.${NC}\n" || \
    printf "${RED}WARNING: Cannot write to disk!${NC}\n"

SAM=""
for c in "$MNT/Windows/System32/config/SAM" "$MNT/windows/system32/config/SAM" \
         "$MNT/WINDOWS/system32/config/SAM" "$MNT/Windows/System32/config/sam"; do
    [ -f "$c" ] && SAM="$c" && break
done
if [ -z "$SAM" ]; then
    printf "${RED}Could not find SAM on this partition.${NC}\n"
    umount "$MNT" 2>/dev/null; rmdir "$MNT"; exit 1
fi
printf "Found SAM at: %s\n" "$SAM"

# =============================================
# LIST USERS — auto-detect from SAM
# =============================================
printf "\n${GREEN}[3/4] Detecting user accounts...${NC}\n"

# Extract usernames from chntpw output
# chntpw -l format: | RID  | Username | Admin? | Lock? |
# Username is the THIRD column (field 3 when split by |)
CHNTPW_OUT=$(chntpw -l "$SAM" 2>/dev/null)
USERLIST=$(echo "$CHNTPW_OUT" | grep "^| " | grep -v "^| RID" | grep -v "^|---" | cut -d'|' -f3 | sed 's/^ *//;s/ *$//' | grep -v "^$")

# Build numbered user list
UCOUNT=0
UNAMES=""
printf "\n${BOLD}  Users found on this Windows install:${NC}\n\n"
for u in $USERLIST; do
    UCOUNT=$((UCOUNT+1))
    UNAMES="$UNAMES $u"
    # Get extra info from chntpw output
    UINFO=$(echo "$CHNTPW_OUT" | grep "| $u " | head -1)
    ADMIN=""
    echo "$UINFO" | grep -qi "admin" && ADMIN=" ${GREEN}(Admin)${NC}"
    LOCK=""
    echo "$UINFO" | grep -qi "lock\|dis" && LOCK=" ${RED}(Locked)${NC}"
    printf "    ${BOLD}%d)${NC} %s%s%s\n" "$UCOUNT" "$u" "$ADMIN" "$LOCK"
done

if [ "$UCOUNT" -eq 0 ]; then
    printf "${YELLOW}    No users detected. Showing raw output:${NC}\n"
    chntpw -l "$SAM" 2>/dev/null
fi

# =============================================
# MAIN MENU
# =============================================
printf "\n${BOLD}${CYAN}========== WHAT DO YOU WANT TO DO? ==========${NC}\n\n"
printf "  ${BOLD}a)${NC} Clear password for a user (set to blank)\n"
printf "  ${BOLD}b)${NC} Clear ALL passwords + PINs at once\n"
printf "  ${BOLD}c)${NC} Remove PINs only (keep passwords)\n"
printf "  ${BOLD}d)${NC} Promote a user to Administrator\n"
printf "  ${BOLD}e)${NC} Enable hidden Administrator account\n"
printf "  ${BOLD}f)${NC} Create a NEW local admin account\n"
printf "\n  ${RED}${BOLD}h) NUKE: Wipe all accounts + create fresh local admin${NC}\n"
printf "     ${YELLOW}(Replaces Ease of Access button - click it on login screen)${NC}\n"
printf "\n  ${BOLD}g)${NC} Connect to WiFi\n"
printf "  ${BOLD}0)${NC} Exit\n"
printf "\n  Choose [a]: "; read ACTION; ACTION=${ACTION:-a}

# Helper: remove Windows Hello PINs, fingerprints, face recognition
remove_pins() {
    printf "  Removing Windows Hello PINs...\n"
    NGC_FOUND=0
    for ngcdir in \
        "$MNT/Windows/ServiceProfiles/LocalService/AppData/Local/Microsoft/Ngc" \
        "$MNT/windows/ServiceProfiles/LocalService/AppData/Local/Microsoft/Ngc" \
        "$MNT/WINDOWS/ServiceProfiles/LocalService/AppData/Local/Microsoft/Ngc"; do
        if [ -d "$ngcdir" ]; then
            rm -rf "$ngcdir"/* 2>/dev/null
            rm -rf "$ngcdir"/.* 2>/dev/null
            NGC_FOUND=1
            printf "    ${GREEN}PIN data cleared from: %s${NC}\n" "$(basename $(dirname $(dirname $(dirname $ngcdir))))"
        fi
    done
    # Also remove any Crypto keys related to NGC
    for cryptodir in \
        "$MNT/Windows/ServiceProfiles/LocalService/AppData/Roaming/Microsoft/Crypto/Keys" \
        "$MNT/ProgramData/Microsoft/Crypto/SystemKeys"; do
        if [ -d "$cryptodir" ]; then
            rm -rf "$cryptodir"/* 2>/dev/null
            printf "    Cleared crypto keys: %s\n" "$(basename $cryptodir)"
        fi
    done
    if [ "$NGC_FOUND" -eq 0 ]; then
        printf "    ${YELLOW}No NGC (PIN) data found.${NC}\n"
    fi
}

# Helper: pick a user by number
pick_user() {
    if [ "$UCOUNT" -eq 0 ]; then
        printf "  Enter username manually: "; read PICKED
        printf "%s" "$PICKED"
        return
    fi
    if [ "$UCOUNT" -eq 1 ]; then
        PICKED=$(echo $UNAMES | tr -d ' ')
        printf "  Auto-selected: %s\n" "$PICKED" >&2
        printf "%s" "$PICKED"
        return
    fi
    printf "  Pick user number [1-%d]: " "$UCOUNT" >&2; read UNUM
    I=1
    for u in $UNAMES; do
        if [ "$I" -eq "$UNUM" ]; then
            printf "%s" "$u"
            return
        fi
        I=$((I+1))
    done
    printf ""
}

case "$ACTION" in
    a|A)
        TARGET=$(pick_user)
        [ -z "$TARGET" ] && printf "${RED}No user selected.${NC}\n" && umount "$MNT" 2>/dev/null && rmdir "$MNT" 2>/dev/null && exit 1
        printf "\n${GREEN}[4/4] Clearing password + PIN for '%s'...${NC}\n" "$TARGET"
        printf "1\nq\ny\n" | chntpw -u "$TARGET" "$SAM" 2>&1 | grep -iE "clear|changed|written|error"
        printf "4\nq\ny\n" | chntpw -u "$TARGET" "$SAM" 2>&1 | grep -iE "unlock|changed|written|error"
        remove_pins
        sync; sync
        umount "$MNT" 2>/dev/null
        printf "\n${GREEN}Password + PIN cleared for %s!${NC}\n" "$TARGET"
        printf "${CYAN}Remove USB and reboot into Windows.${NC}\n"
        printf "\nPress Enter..."; read dummy
        exit 0
        ;;
    b|B)
        printf "\n${GREEN}[4/4] Clearing ALL passwords...${NC}\n\n"

        # Make a backup first
        cp "$SAM" "${SAM}.bak" 2>/dev/null

        for u in $UNAMES; do
            printf "  --- %s ---\n" "$u"
            # Method 1: chntpw interactive - clear password
            printf "1\nq\ny\n" | chntpw -u "$u" "$SAM" 2>&1 | grep -iE "clear|changed|written|error"
            # Method 2: chntpw interactive - unlock account too
            printf "4\nq\ny\n" | chntpw -u "$u" "$SAM" 2>&1 | grep -iE "unlock|changed|written|error"
        done

        # Remove all PINs too
        remove_pins

        # Force flush to disk
        sync
        sync
        # Verify SAM was actually modified
        if [ -f "${SAM}.bak" ]; then
            if cmp -s "$SAM" "${SAM}.bak"; then
                printf "\n${RED}WARNING: SAM file did NOT change! Filesystem may be read-only.${NC}\n"
                printf "Mount info: %s\n" "$(mount | grep "$MNT")"
            else
                printf "\n${GREEN}SAM file modified successfully.${NC}\n"
            fi
            rm -f "${SAM}.bak" 2>/dev/null
        fi

        # Unmount and remount to force write-back
        umount "$MNT" 2>/dev/null
        sleep 1

        printf "\n${GREEN}All passwords cleared and accounts unlocked!${NC}\n"
        printf "${CYAN}Remove USB and reboot into Windows now.${NC}\n"
        printf "\nPress Enter..."; read dummy
        exit 0
        ;;
    c|C)
        printf "\n${GREEN}[4/4] Removing all PINs...${NC}\n"
        remove_pins
        sync; sync
        umount "$MNT" 2>/dev/null
        printf "\n${GREEN}All PINs removed!${NC}\n"
        printf "${CYAN}Remove USB and reboot into Windows.${NC}\n"
        printf "\nPress Enter..."; read dummy
        exit 0
        ;;
    d|D)
        TARGET=$(pick_user)
        [ -z "$TARGET" ] && printf "${RED}No user selected.${NC}\n" && umount "$MNT" 2>/dev/null && rmdir "$MNT" 2>/dev/null && exit 1
        printf "\n${GREEN}[4/4] Promoting '%s' to Administrator...${NC}\n" "$TARGET"
        printf "3\nq\ny\n" | chntpw -u "$TARGET" "$SAM"
        printf "\n${GREEN}%s promoted to Administrator.${NC}\n" "$TARGET"
        ;;
    e|E)
        printf "\n${CYAN}  This enables the hidden built-in Administrator account.${NC}\n"
        printf "  After reboot you will see Administrator on the login screen.\n\n"
        printf "${GREEN}[4/4] Enabling built-in Administrator...${NC}\n"
        printf "1\nq\ny\n" | chntpw -u "Administrator" "$SAM" 2>/dev/null
        printf "4\nq\ny\n" | chntpw -u "Administrator" "$SAM" 2>/dev/null
        printf "\n${GREEN}Built-in Administrator account enabled!${NC}\n"
        printf "\n${BOLD}After reboot:${NC}\n"
        printf "  1. On login screen click Administrator\n"
        printf "  2. Log in with no password\n"
        printf "  3. Open Settings > Accounts to manage others\n"
        printf "\n${YELLOW}  Tip: Disable this account when done.${NC}\n"
        ;;
    f|F)
        printf "\n${CYAN}  Creates a new local admin account.${NC}\n\n"
        printf "  Enter new username: "; read NEWUSER
        [ -z "$NEWUSER" ] && printf "${RED}No username.${NC}\n" && umount "$MNT" 2>/dev/null && rmdir "$MNT" 2>/dev/null && exit 1
        printf "  Enter password (blank for none): "
        stty -echo 2>/dev/null; read NEWUSERPW; stty echo 2>/dev/null; printf "\n"
        printf "\n${GREEN}[4/4] Setting up '%s'...${NC}\n" "$NEWUSER"
        printf "1\nq\ny\n" | chntpw -u "Administrator" "$SAM" 2>/dev/null
        printf "4\nq\ny\n" | chntpw -u "Administrator" "$SAM" 2>/dev/null
        SETUP_DIR="$MNT/Windows/Setup/Scripts"
        mkdir -p "$SETUP_DIR" 2>/dev/null
        if [ -n "$NEWUSERPW" ]; then
            NET_CMD="net user $NEWUSER $NEWUSERPW /add && net localgroup Administrators $NEWUSER /add"
        else
            NET_CMD="net user $NEWUSER /add && net localgroup Administrators $NEWUSER /add"
        fi
        printf "@echo off\r\n%s\r\n" "$NET_CMD" > "$SETUP_DIR/SetupComplete.cmd"
        STARTUP_DIR="$MNT/ProgramData/Microsoft/Windows/Start Menu/Programs/Startup"
        if [ -d "$STARTUP_DIR" ] || mkdir -p "$STARTUP_DIR" 2>/dev/null; then
            printf "@echo off\r\n%s\r\n" "$NET_CMD" > "$STARTUP_DIR/create-account.bat"
        fi
        printf "\n${GREEN}Account setup prepared!${NC}\n"
        printf "\n${BOLD}After reboot:${NC}\n"
        printf "  1. Log in as Administrator (no password)\n"
        printf "  2. Account '%s' will be created automatically\n" "$NEWUSER"
        printf "\n${YELLOW}  Tip: Disable Administrator when done.${NC}\n"
        ;;
    h|H)
        printf "\n${RED}${BOLD}  === NUKE MODE ===${NC}\n\n"
        printf "  This will:\n"
        printf "    - Replace Ease of Access button with a setup script\n"
        printf "    - On reboot, click the accessibility icon on login screen\n"
        printf "    - It auto-creates a new local admin and removes old accounts\n\n"

        printf "  Enter new username: "; read NUKE_USER
        [ -z "$NUKE_USER" ] && printf "${RED}No username.${NC}\n" && umount "$MNT" 2>/dev/null && rmdir "$MNT" 2>/dev/null && exit 1
        printf "  Enter password (blank for none): "
        stty -echo 2>/dev/null; read NUKE_PASS; stty echo 2>/dev/null; printf "\n"

        printf "\n${GREEN}[4/4] Setting up NUKE...${NC}\n"

        # Find System32
        SYS32=""
        for d in "$MNT/Windows/System32" "$MNT/windows/system32" "$MNT/WINDOWS/system32"; do
            [ -d "$d" ] && SYS32="$d" && break
        done

        if [ -z "$SYS32" ]; then
            printf "${RED}Could not find System32.${NC}\n"
            umount "$MNT" 2>/dev/null; rmdir "$MNT" 2>/dev/null; exit 1
        fi

        # Back up Utilman.exe
        if [ -f "$SYS32/Utilman.exe" ]; then
            cp "$SYS32/Utilman.exe" "$SYS32/Utilman.exe.bak" 2>/dev/null
            printf "  Backed up Utilman.exe\n"
        fi

        # Copy cmd.exe over Utilman.exe
        cp "$SYS32/cmd.exe" "$SYS32/Utilman.exe" 2>/dev/null
        printf "  Replaced Utilman.exe with cmd.exe\n"

        # Create the auto-fix batch script
        if [ -n "$NUKE_PASS" ]; then
            NET_ADD="net user $NUKE_USER $NUKE_PASS /add"
        else
            NET_ADD="net user $NUKE_USER /add"
        fi

        # Build the fix script - creates account, enables admin, removes old accounts, restores Utilman
        printf "@echo off\r\n" > "$SYS32/fix.bat"
        printf "echo ==========================================\r\n" >> "$SYS32/fix.bat"
        printf "echo   Creating account: %s\r\n" "$NUKE_USER" >> "$SYS32/fix.bat"
        printf "echo ==========================================\r\n" >> "$SYS32/fix.bat"
        printf "%s\r\n" "$NET_ADD" >> "$SYS32/fix.bat"
        printf "net localgroup Administrators %s /add\r\n" "$NUKE_USER" >> "$SYS32/fix.bat"
        printf "echo.\r\n" >> "$SYS32/fix.bat"
        printf "echo Account created! Now removing old accounts...\r\n" >> "$SYS32/fix.bat"

        # Delete all detected users except the new one and built-in accounts
        for u in $UNAMES; do
            case "$u" in
                Administrator|Guest|DefaultAccount|WDAGUtilityAccount) continue ;;
            esac
            printf "net user \"%s\" /delete 2>nul\r\n" "$u" >> "$SYS32/fix.bat"
            printf "echo   Removed: %s\r\n" "$u" >> "$SYS32/fix.bat"
        done

        printf "echo.\r\n" >> "$SYS32/fix.bat"
        printf "echo Restoring Ease of Access button...\r\n" >> "$SYS32/fix.bat"
        printf "copy /Y \"%%SystemRoot%%\\System32\\Utilman.exe.bak\" \"%%SystemRoot%%\\System32\\Utilman.exe\" >nul 2>&1\r\n" >> "$SYS32/fix.bat"
        printf "echo.\r\n" >> "$SYS32/fix.bat"
        printf "echo ==========================================\r\n" >> "$SYS32/fix.bat"
        printf "echo   DONE! Close this window and sign in\r\n" >> "$SYS32/fix.bat"
        printf "echo   as: %s\r\n" "$NUKE_USER" >> "$SYS32/fix.bat"
        printf "echo ==========================================\r\n" >> "$SYS32/fix.bat"
        printf "pause\r\n" >> "$SYS32/fix.bat"

        # Also clear SAM passwords and PINs for good measure
        for u in $UNAMES; do
            printf "1\nq\ny\n" | chntpw -u "$u" "$SAM" >/dev/null 2>&1
            printf "4\nq\ny\n" | chntpw -u "$u" "$SAM" >/dev/null 2>&1
        done
        # Enable Administrator too as backup
        printf "1\nq\ny\n" | chntpw -u "Administrator" "$SAM" >/dev/null 2>&1
